ANTHROPIC_API_KEY=sk-ant-DEIN-KEY-HIER
# Google Maps API Key — muss Geocoding API, Directions API und Places API aktiviert haben
GOOGLE_MAPS_API_KEY=
TEST_MODE=true
# Lokal: redis://localhost:6379 / UTM VM: Host-IP z.B. redis://192.168.64.1:6379
REDIS_URL=redis://localhost:6379
OUTPUTS_DIR=./outputs

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT secret — mindestens 32 Zeichen; generieren mit:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# Admin-Bootstrap: wird beim Start automatisch erstellt, falls kein Admin existiert
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# COOKIE_SECURE=true im Produktionsbetrieb (HTTPS), false für lokale Entwicklung
COOKIE_SECURE=false
